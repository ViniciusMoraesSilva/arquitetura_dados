sequenceDiagram
    autonumber

    participant Origem as Origem / Evento de Carga
    participant EB as EventBridge
    participant SFN_ING as SFN Ingestão SOR
    participant LPrepIng as Lambda Preparar Ingestão
    participant DDB as DynamoDB pipeline_control
    participant GlueSOR as Glue Carga SOR
    participant SOR as S3 / SOR
    participant LFinIng as Lambda Finalizar Ingestão

    participant Operador as Operador / Disparo FULL
    participant SFN_FULL as SFN FULL Seguros
    participant LPrepFull as Lambda Preparar FULL Genérica
    participant GlueModX as Glue Módulo X
    participant GlueModY as Glue Módulo Y
    participant GlueModZ as Glue Módulo Z
    participant SOT as S3 / SOT
    participant GlueCons as Glue Consolidação
    participant GlueSpec as Glue Publicação SPEC
    participant SPEC as S3 / SPEC

    %% =====================================================
    %% 1. EVENTO DE ORIGEM
    %% =====================================================

    Origem->>EB: Publica evento de tabela disponível<br/>database_name, table_name, data_referencia, partition_values

    EB->>SFN_ING: Dispara sfn-orq-ingestao-sor

    %% =====================================================
    %% 2. PREPARAR INGESTÃO
    %% =====================================================

    SFN_ING->>LPrepIng: Chama Lambda preparar-ingestao

    LPrepIng->>LPrepIng: Gera ingestion_id<br/>Ex: ing_100

    LPrepIng->>LPrepIng: Monta source_push_down_predicate<br/>Ex: data_referencia='2026-04'

    LPrepIng->>DDB: Cria INGESTION_ID#ing_100 / METADATA<br/>status = PROCESSING

    LPrepIng-->>SFN_ING: Retorna ingestion_id

    %% =====================================================
    %% 3. CARGA PARA SOR
    %% =====================================================

    SFN_ING->>GlueSOR: Executa Glue carga-sor<br/>Parâmetro: ingestion_id

    GlueSOR->>DDB: Busca INGESTION_ID#ing_100 / METADATA

    DDB-->>GlueSOR: Retorna origem, tabela e predicate

    GlueSOR->>Origem: Lê tabela origem com push_down_predicate

    GlueSOR->>SOR: Grava dados na SOR<br/>com ingestion_id

    %% =====================================================
    %% 4. FINALIZAR INGESTÃO
    %% =====================================================

    GlueSOR-->>SFN_ING: Carga finalizada com sucesso

    SFN_ING->>LFinIng: Chama Lambda finalizar-carga-sor-sucesso

    LFinIng->>DDB: Atualiza INGESTION_ID#ing_100<br/>status = SOR_LOADED

    LFinIng->>DDB: Cria INGESTION_HISTORY#contratos#2026-04<br/>INGESTION#ing_100

    LFinIng->>DDB: Atualiza CURRENT_SOR#contratos#2026-04<br/>current_ingestion_id = ing_100

    LFinIng-->>SFN_ING: Finalização OK

    %% =====================================================
    %% 5. REPETE PARA OUTRAS TABELAS
    %% =====================================================

    Note over Origem,DDB: O mesmo fluxo acontece para clientes, parcelas e demais tabelas.<br/>Ao final teremos CURRENT_SOR de cada tabela.

    %% =====================================================
    %% 6. DISPARO FULL
    %% =====================================================

    Operador->>SFN_FULL: Dispara sfn-orq-full-seguros<br/>data_referencia = 2026-04

    SFN_FULL->>LPrepFull: Chama Lambda preparar-full-generica<br/>process_name = seguros<br/>data_referencia = 2026-04

    %% =====================================================
    %% 7. PREPARAR FULL
    %% =====================================================

    LPrepFull->>DDB: Consulta FULL_CONFIG#seguros

    DDB-->>LPrepFull: Retorna tabelas do FULL<br/>contratos, clientes, parcelas

    LPrepFull->>DDB: Busca CURRENT_SOR#contratos#2026-04

    DDB-->>LPrepFull: contratos = ing_100

    LPrepFull->>DDB: Busca CURRENT_SOR#clientes#2026-04

    DDB-->>LPrepFull: clientes = ing_200

    LPrepFull->>DDB: Busca CURRENT_SOR#parcelas#2026-04

    DDB-->>LPrepFull: parcelas = ing_300

    LPrepFull->>LPrepFull: Gera process_id<br/>Ex: proc_seguros_202604_001

    LPrepFull->>DDB: Cria PROCESS#proc_seguros_202604_001 / HEADER<br/>status = LOCKING_INPUTS

    LPrepFull->>DDB: Cria PROCESS_LIST#seguros#2026-04<br/>PROCESS#proc_seguros_202604_001

    LPrepFull->>DDB: Cria INPUT_LOCK#contratos<br/>ingestion_id = ing_100

    LPrepFull->>DDB: Cria INPUT_LOCK#clientes<br/>ingestion_id = ing_200

    LPrepFull->>DDB: Cria INPUT_LOCK#parcelas<br/>ingestion_id = ing_300

    LPrepFull->>DDB: Atualiza PROCESS HEADER<br/>status = RUNNING

    LPrepFull-->>SFN_FULL: Retorna process_id

    %% =====================================================
    %% 8. MÓDULO X
    %% =====================================================

    SFN_FULL->>DDB: Cria/atualiza STEP#MODULO_X<br/>status = RUNNING

    SFN_FULL->>GlueModX: Executa Módulo X<br/>process_id

    GlueModX->>DDB: Busca INPUT_LOCK#contratos

    DDB-->>GlueModX: ingestion_id = ing_100

    GlueModX->>DDB: Busca INPUT_LOCK#clientes

    DDB-->>GlueModX: ingestion_id = ing_200

    GlueModX->>SOR: Lê SOR usando ingestion_id<br/>ingestion_id='ing_100'<br/>ingestion_id='ing_200'

    GlueModX->>SOT: Grava saída do módulo X<br/>com process_id

    GlueModX-->>SFN_FULL: Módulo X finalizado

    SFN_FULL->>DDB: Atualiza STEP#MODULO_X<br/>status = SUCCESS

    %% =====================================================
    %% 9. MÓDULO Y
    %% =====================================================

    SFN_FULL->>DDB: Cria/atualiza STEP#MODULO_Y<br/>status = RUNNING

    SFN_FULL->>GlueModY: Executa Módulo Y<br/>process_id

    GlueModY->>DDB: Busca INPUT_LOCK das tabelas necessárias

    DDB-->>GlueModY: Retorna ingestion_id das tabelas

    GlueModY->>SOR: Lê SOR usando somente ingestion_id

    GlueModY->>SOT: Grava saída do módulo Y<br/>com process_id

    GlueModY-->>SFN_FULL: Módulo Y finalizado

    SFN_FULL->>DDB: Atualiza STEP#MODULO_Y<br/>status = SUCCESS

    %% =====================================================
    %% 10. MÓDULO Z
    %% =====================================================

    SFN_FULL->>DDB: Cria/atualiza STEP#MODULO_Z<br/>status = RUNNING

    SFN_FULL->>GlueModZ: Executa Módulo Z<br/>process_id

    GlueModZ->>DDB: Busca INPUT_LOCK das tabelas necessárias

    DDB-->>GlueModZ: Retorna ingestion_id das tabelas

    GlueModZ->>SOR: Lê SOR usando somente ingestion_id

    GlueModZ->>SOT: Grava saída do módulo Z<br/>com process_id

    GlueModZ-->>SFN_FULL: Módulo Z finalizado

    SFN_FULL->>DDB: Atualiza STEP#MODULO_Z<br/>status = SUCCESS

    %% =====================================================
    %% 11. CONSOLIDAÇÃO SOT
    %% =====================================================

    SFN_FULL->>DDB: Cria/atualiza STEP#CONSOLIDATION<br/>status = RUNNING

    SFN_FULL->>GlueCons: Executa consolidação<br/>process_id

    GlueCons->>SOT: Lê saídas dos módulos<br/>filtrando por process_id

    GlueCons->>SOT: Grava tabela consolidada<br/>com process_id

    GlueCons-->>SFN_FULL: Consolidação finalizada

    SFN_FULL->>DDB: Atualiza STEP#CONSOLIDATION<br/>status = SUCCESS

    %% =====================================================
    %% 12. PUBLICAÇÃO SPEC
    %% =====================================================

    SFN_FULL->>DDB: Cria/atualiza STEP#PUBLICATION<br/>status = RUNNING

    SFN_FULL->>GlueSpec: Executa publicação SPEC<br/>process_id

    GlueSpec->>SOT: Lê SOT consolidada<br/>filtrando por process_id

    GlueSpec->>SPEC: Grava visão oficial SPEC

    GlueSpec-->>SFN_FULL: Publicação finalizada

    SFN_FULL->>DDB: Atualiza STEP#PUBLICATION<br/>status = SUCCESS

    SFN_FULL->>DDB: Atualiza PROCESS HEADER<br/>status = PUBLISHED

    SFN_FULL->>DDB: Atualiza PROCESS_LIST<br/>status = PUBLISHED

    %% =====================================================
    %% FIM
    %% =====================================================

    SFN_FULL-->>Operador: Processo FULL finalizado<br/>status = PUBLISHED