sequenceDiagram
    autonumber

    participant Origem as Origem / Evento
    participant SFN_ING as SFN Ingestão SOR
    participant LReg as Lambda Registrar Ingestão
    participant DDB as DynamoDB pipeline_control
    participant GlueSOR as Glue Job SOR

    participant Operador as Operador / Disparo FULL
    participant SFN_FULL as SFN FULL do Processo
    participant LFull as Lambda Preparar FULL Genérica
    participant GlueMod as Glue Módulo

    %% =====================================================
    %% FALHA NA INGESTÃO SOR
    %% =====================================================

    Origem->>SFN_ING: Evento de tabela disponível

    SFN_ING->>LReg: Registrar ingestão

    LReg->>DDB: Cria INGESTION_ID#ing_100<br/>status = PENDING_PROCESSING

    SFN_ING->>DDB: Atualiza INGESTION_ID#ing_100<br/>status = PROCESSING_SOR

    SFN_ING->>GlueSOR: Executa Glue SOR<br/>ingestion_id

    alt Glue SOR falha
        GlueSOR-->>SFN_ING: Erro na carga SOR

        SFN_ING->>DDB: Atualiza INGESTION_ID#ing_100<br/>status = PROCESSING_FAILURE<br/>error_message = motivo da falha

        SFN_ING->>DDB: Não atualiza CURRENT_SOR

        Note over DDB: Como CURRENT_SOR não foi atualizado,<br/>essa versão não será usada automaticamente no FULL.
    else Glue SOR sucesso
        GlueSOR-->>SFN_ING: Sucesso

        SFN_ING->>DDB: Atualiza INGESTION_ID#ing_100<br/>status = LOADED_SOR

        SFN_ING->>DDB: Atualiza CURRENT_SOR#processo#tabela
    end

    %% =====================================================
    %% FALTA DE CURRENT_SOR NO FULL
    %% =====================================================

    Operador->>SFN_FULL: Dispara FULL

    SFN_FULL->>LFull: Chama preparar FULL<br/>process_name + input_overrides opcional

    LFull->>DDB: Consulta FULL_CONFIG#seguros

    DDB-->>LFull: Retorna tabelas obrigatórias

    LFull->>DDB: Busca CURRENT_SOR#seguros#contratos

    alt CURRENT_SOR não encontrado
        DDB-->>LFull: Não encontrado

        LFull->>DDB: Cria PROCESS HEADER<br/>status = FAILED_INPUT_MISSING<br/>missing_table = contratos

        LFull-->>SFN_FULL: Retorna erro de input faltante

        SFN_FULL-->>Operador: FULL não iniciado<br/>motivo: tabela obrigatória sem CURRENT_SOR
    else CURRENT_SOR encontrado
        DDB-->>LFull: Retorna current_ingestion_id

        LFull->>DDB: Continua criação dos INPUT_LOCKS
    end

    %% =====================================================
    %% OVERRIDE INVÁLIDO
    %% =====================================================

    Operador->>SFN_FULL: Dispara FULL com input_overrides<br/>{"contratos": "ing_090"}

    SFN_FULL->>LFull: Chama preparar FULL

    LFull->>DDB: Valida INGESTION_ID#ing_090

    alt INGESTION_ID não existe
        DDB-->>LFull: Não encontrado

        LFull->>DDB: Cria/atualiza PROCESS HEADER<br/>status = FAILED_INVALID_OVERRIDE<br/>table_name = contratos<br/>ingestion_id = ing_090

        LFull-->>SFN_FULL: Retorna erro

        SFN_FULL-->>Operador: FULL não iniciado<br/>motivo: override inválido

    else INGESTION_ID existe mas não está LOADED_SOR
        DDB-->>LFull: status != LOADED_SOR

        LFull->>DDB: Cria/atualiza PROCESS HEADER<br/>status = FAILED_INVALID_OVERRIDE<br/>motivo = ingestion não carregada na SOR

        LFull-->>SFN_FULL: Retorna erro

    else Override válido
        DDB-->>LFull: status = LOADED_SOR

        LFull->>DDB: Cria INPUT_LOCK<br/>lock_source = OVERRIDE

        LFull->>DDB: Continua preparação do FULL
    end

    %% =====================================================
    %% FALHA EM MÓDULO / CONSOLIDAÇÃO / PUBLICAÇÃO
    %% =====================================================

    SFN_FULL->>GlueMod: Executa módulo<br/>process_id

    alt Módulo falha
        GlueMod-->>SFN_FULL: Erro no Glue Job

        SFN_FULL->>DDB: Atualiza PROCESS HEADER<br/>status = PROCESSING_FAILURE<br/>failed_stage = MODULO_X

        SFN_FULL->>DDB: Atualiza PROCESS_LIST<br/>status = PROCESSING_FAILURE

        SFN_FULL-->>Operador: FULL falhou
    else Módulo sucesso
        GlueMod-->>SFN_FULL: Sucesso

        Note over SFN_FULL: Step Functions segue para o próximo estado.<br/>Status detalhado fica no histórico da própria SFN/Glue/CloudWatch.
    end